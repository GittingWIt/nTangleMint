{
  "buildCommand": "next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_NETWORK_MODE": "@NEXT_PUBLIC_NETWORK_MODE",
    "NEXT_PUBLIC_WALLET_SALT": "@NEXT_PUBLIC_WALLET_SALT",
    "NEXT_PUBLIC_DEBUG_MODE": "@NEXT_PUBLIC_DEBUG_MODE",
    "NEXT_PUBLIC_RECAPTCHA_SITE_KEY": "@NEXT_PUBLIC_RECAPTCHA_SITE_KEY",
    "NEXT_PUBLIC_BSV_NETWORK": "@NEXT_PUBLIC_BSV_NETWORK",
    "NEXT_PUBLIC_PROGRAM_VERSION": "@NEXT_PUBLIC_PROGRAM_VERSION",
    "NEXT_PUBLIC_STORAGE_PREFIX": "@NEXT_PUBLIC_STORAGE_PREFIX",
    "NEXT_PUBLIC_RESET_STORAGE": "@NEXT_PUBLIC_RESET_STORAGE",
    "NEXT_PHASE": "@NEXT_PHASE",
    "NEXT_TELEMETRY_DISABLED": "@NEXT_TELEMETRY_DISABLED",
    "CORS_ALLOWED_ORIGINS": "@CORS_ALLOWED_ORIGINS",
    "RECAPTCHA_SECRET_KEY": "@RECAPTCHA_SECRET_KEY",
    "SENTRY_DSN": "@SENTRY_DSN",
    "UPSTASH_REDIS_REST_TOKEN": "@UPSTASH_REDIS_REST_TOKEN",
    "UPSTASH_REDIS_REST_URL": "@UPSTASH_REDIS_REST_URL"
  },
  "functions": {
    "app/api/**": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "regions": ["iad1"],
  "git": {
    "deploymentEnabled": true
  }
}