{
  "name": "ntanglemint-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "nTangleMint - BSV-first loyalty program platform",
  "keywords": [
    "bsv",
    "blockchain",
    "loyalty",
    "rust",
    "nextjs"
  ],
  "author": "nTangleMint Team",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build:rust": "cd packages/bsv-core && wasm-pack build --target web --out-dir pkg --release",
    "build:rust:dev": "cd packages/bsv-core && wasm-pack build --target web --out-dir pkg --dev",
    "build": "npm run build:rust && next build",
    "build:analyze": "ANALYZE=true npm run build",
    "postbuild": "node scripts/fix-build-output.js",
    "start": "next start",
    "start:prod": "NODE_ENV=production next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "dev:rust": "cd packages/bsv-core && cargo build",
    "test:rust": "cd packages/bsv-core && cargo test",
    "test:rust:watch": "cd packages/bsv-core && cargo watch -x test",
    "test:crypto": "node app/test-bsv/crypto-test.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:e2e": "playwright test",
    "clean": "rm -rf .next node_modules/.cache packages/bsv-core/pkg packages/bsv-core/target",
    "clean:deps": "rm -rf node_modules package-lock.json && npm install",
    "find-imports": "ts-node scripts/find-missing-imports.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install || true",
    "precommit": "lint-staged",
    "postinstall": "npm run build:rust:dev"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@noble/hashes": "^1.4.0",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@react-three/drei": "^9.99.5",
    "@react-three/fiber": "^8.15.16",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.0.28",
    "lucide-react": "^0.400.0",
    "next": "^16.2.3",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.1",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.4.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.166.1",
    "three-mesh-bvh": "^0.7.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@next/bundle-analyzer": "^14.2.28",
    "@playwright/test": "^1.45.3",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.166.0",
    "autoprefixer": "^10.4.19",
    "buffer": "^6.0.3",
    "concurrently": "^8.2.2",
    "crypto-browserify": "^3.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^16.2.3",
    "husky": "^9.1.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^15.2.7",
    "path-browserify": "^1.0.1",
    "postcss": "^8.4.40",
    "postcss-preset-env": "^9.6.0",
    "prettier": "^3.3.3",
    "stream-browserify": "^3.0.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "wasm-pack": "^0.0.0"
  },
  "browser": {
    "crypto": false,
    "fs": false,
    "path": false,
    "os": false
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "moduleNameMapping": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
